  dialogue:
  - who: Pegasister
    text: Oh my!! A NEIGH-t!!
    voice: {fileID: 0}
    answers: []
  - who: Pegasister
    text: Such noble armour you have! Your owner must take such good care of you.
    voice: {fileID: 0}
    answers: []
  - who: Pegasister
    text: "Don\u2019t worry pretty, I won\u2019t try to ride you!!"
    voice: {fileID: 0}
    answers: []
  - who: Pegasister
    text: "What\u2019s that? In your land NEIGHHH-ts ride HORSES??"
    voice: {fileID: 0}
    answers: []
  - who: Pegasister
    text: "Hehehe don\u2019t be ridiculous!! I know horseplay when I hear it!"
    voice: {fileID: 0}
    answers: []
  - who: Pegasister
    text: Here have a treat! I know you NEIGHH-ts love them <3
    voice: {fileID: 0}
