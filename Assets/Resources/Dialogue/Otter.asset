  dialogue:
  - who: Otter
    text: I am the alpha and the omega.
    voice: {fileID: 8300000, guid: 99da06e07ced44a48b4af2a1474f6efd, type: 3}
    nextBattleState: 2
    nextWheelEffect: {fileID: 0}
  - who: Otter
    text: The first and the last.
    voice: {fileID: 8300000, guid: fa8ebafe0e70867479b555639d8c7063, type: 3}
    nextBattleState: 2
    nextWheelEffect: {fileID: 0}
  - who: Otter
    text: The beginning and the end.
    voice: {fileID: 8300000, guid: fd3d1c931574c304c8f0685834f40888, type: 3}
    nextBattleState: 2
    nextWheelEffect: {fileID: 0}
  - who: Otter
    text: "And I\u2019m sooooooo hungry >:3"
    voice: {fileID: 8300000, guid: 6a2451ca18eeb124495b31fae65d0771, type: 3}
    nextBattleState: 2
    nextWheelEffect: {fileID: 0}
  - who: Otter
    text: "Mmmmm fibsh\u2026."
