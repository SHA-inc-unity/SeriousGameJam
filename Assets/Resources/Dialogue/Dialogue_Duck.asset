  m_Script: {fileID: 11500000, guid: 3e1c30283a333a443b4b63a507555694, type: 3}
  m_Name: Dialogue_Duck
  m_EditorClassIdentifier: Assembly-CSharp::DialogueHolder
  dialogue:
  - who: Sirius
    text: "Ugh.. the last trial.. leviathan is within reach\u2026"
    voice: {fileID: 8300000, guid: bfd78e444a89164469c46ff157fe1f30, type: 3}
    answers: []
  - who: Duckles
    text: Ohoho! Would you care for a game young lady?
    voice: {fileID: 8300000, guid: b2b9b604668c8e04ab7de2123674665e, type: 3}
    answers: []
  - who: Sirius
    text: I know how things are run in this hellscape. Hurry it up.
    voice: {fileID: 8300000, guid: 51ff288df92909c4aa329ded13185ba8, type: 3}
    answers: []
  - who: Duckles
    text: Ohoho! You quack me up!
    voice: {fileID: 8300000, guid: 204ec5e4851ffb04f91bbc89be3dc4da, type: 3}
    answers: []
  - who: Duckles
    text: Catch the ducks and win a prize.
    voice: {fileID: 8300000, guid: 5ad4a7f9a36ad864a9d622ecbd28fcf9, type: 3}
    answers: []
  - who: Duckles
    text: "Just go with the flow, I\u2019m sure you fit the bill!"
    voice: {fileID: 8300000, guid: e51176435b30d4145b6ad945d573b88b, type: 3}
    answers: []
